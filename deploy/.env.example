# n8n Self-Hosting — Umgebungsvariablen (VORLAGE)
# Kopieren:  cp deploy/.env.example deploy/.env   und Werte setzen.
# NIEMALS die echte .env committen (steht in .gitignore-Empfehlung, siehe SELF-HOSTING.md).

# --- Postgres ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_starkes_passwort
POSTGRES_DB=n8n

# --- Öffentliche Adresse ---
# Domain, unter der n8n erreichbar ist (ohne Protokoll), z. B. n8n.deinedomain.de
N8N_HOST=localhost
# http (nur lokal) oder https (mit Domain/Proxy)
N8N_PROTOCOL=http
# Lokaler Port (Container lauscht intern immer auf 5678)
N8N_PORT=5678
# Voll-URL inkl. Protokoll — WICHTIG für korrekte Webhook-Links.
# Lokal:   http://localhost:5678/
# Domain:  https://n8n.deinedomain.de/
WEBHOOK_URL=http://localhost:5678/

# --- Credentials-Verschlüsselung (STABIL halten!) ---
# Einmalig erzeugen und NIE wieder ändern:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# --- Zeitzone ---
GENERIC_TIMEZONE=Europe/Berlin

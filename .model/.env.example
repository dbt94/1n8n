# .model/.env — Verdrahtung der 1n8n-Speiche zum Model. Echte Werte NIE committen.
#
# MODEL_DIR: Pfad zum ausgecheckten MasterModel.bd-Repo (der mm-Kern liegt in $MODEL_DIR/bin/mm).
#            Der Execute-Command-Node läuft mit shell:true → ${MODEL_DIR} wird von der Shell expandiert.
MODEL_DIR=/absolute/pfad/zu/MasterModel.bd

# OMNIROUTE_BASE_URL: zentrales LLM-Gateway (ein Key, alle Provider). AI-Agent-Nodes zeigen auf ${OMNIROUTE_BASE_URL}/v1.
OMNIROUTE_BASE_URL=http://localhost:20128
OMNIROUTE_API_KEY=

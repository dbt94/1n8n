# .model/deploy/.env — Self-Host-Konfiguration. Kopie nach .env, echte Werte NIE committen.

# ── Pflicht ──────────────────────────────────────────────────────────
# Absoluter Pfad zum ausgecheckten MasterModel.bd auf DIESEM Host (wird als /model:ro gemountet).
MODEL_DIR=/absolute/pfad/zu/MasterModel.bd
# Postgres-Passwort (frei wählen).
POSTGRES_PASSWORD=change-me-strong
# n8n-Verschlüsselungs-Key (persistiert Credentials über Neustarts). Erzeugen: openssl rand -hex 24
N8N_ENCRYPTION_KEY=change-me-openssl-rand-hex-24

# ── Optional (Defaults im Compose) ───────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
N8N_PORT_HOST=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TZ=Europe/Berlin
# n8n-Image (offiziell; für die eigene Fork-Build hier den selbst gebauten Tag eintragen).
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
# LLM-Gateway (OmniRoute). Im geteilten Netz: http://omniroute:20128
OMNIROUTE_BASE_URL=http://omniroute:20128
